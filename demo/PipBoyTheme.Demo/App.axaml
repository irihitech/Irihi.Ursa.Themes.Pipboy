<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PipBoyTheme.Demo.App"
             xmlns:local="using:PipBoyTheme.Demo"
             xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
             xmlns:pipBoy="clr-namespace:Irihi.Ursa.Themes.PipBoy;assembly=Irihi.Ursa.Themes.PipBoy"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <pipboy:PipboyTheme />
        <pipBoy:UrsaPipboyTheme/>
    </Application.Styles>
</Application>