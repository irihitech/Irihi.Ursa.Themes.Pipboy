<UserControl
    x:Class="PipBoyTheme.Demo.Pages.UrsaOverviewPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:pages="clr-namespace:PipBoyTheme.Demo.Pages"
    x:DataType="pages:OverviewDemoViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <pipboy:CrtDisplay
        x:Name="OverviewCrt"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        EnableFlicker="False"
        EnableNoise="True"
        EnableScanBeam="True"
        EnableScanlineAnimation="False"
        EnableScanlines="True"
        EnableVignette="True"
        NoiseDensity="0.015"
        NoiseOpacity="0.04"
        ScanBeamHeight="50"
        ScanBeamSpeed="55"
        ScanlineOpacity="0.22"
        ScanlineSpacing="3"
        VignetteIntensity="0.38">

        <Panel>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" Spacing="8">
                    <!--  Welcome Banner  -->
                    <u:Banner
                        Classes="Bordered"
                        Content="Aesthetic revolution of productivity. Explore Ursa controls below."
                        Header="Welcome to Ursa.Avalonia!"
                        Type="Information" />

                    <!--  Marquee  -->
                    <u:Marquee
                        Height="40"
                        Content="This is a scrolling marquee text - Ursa.Avalonia UI Library"
                        Speed="40" />

                    <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                        <!--  Row 0 - Avatars, Badges, Button Groups  -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Avatars" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <u:Avatar Classes="Red Small" Content="R" />
                                    <u:Avatar Classes="Blue Small" Content="B" />
                                    <u:Avatar Classes="Green Small" Content="G" />
                                    <u:Avatar Classes="Square Orange Small" Content="S" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="0"
                            Grid.Column="1"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Badges" />
                                <WrapPanel Orientation="Horizontal">
                                    <u:Badge Classes="Primary" Header="5">
                                        <u:Avatar Classes="Blue Small" Content="A" />
                                    </u:Badge>
                                    <u:Badge
                                        Classes="Success"
                                        Header="99"
                                        OverflowCount="50">
                                        <u:Avatar Classes="Green Small" Content="B" />
                                    </u:Badge>
                                    <u:Badge Classes="Warning" Dot="True">
                                        <u:Avatar Classes="Amber Small" Content="C" />
                                    </u:Badge>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="0"
                            Grid.Column="2"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Button Groups" />
                                <u:ButtonGroup Classes="Primary Small" ItemsSource="{Binding ButtonGroupItems}" />
                                <u:ButtonGroup Classes="Success Small" ItemsSource="{Binding ButtonGroupItems}" />
                            </StackPanel>
                        </Border>

                        <!--  Row 1 - Icon Buttons, Rating, Dividers  -->
                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Icon Buttons" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <u:IconButton Classes="Small" Icon="{StaticResource SemiIconCamera}" />
                                    <u:IconButton Classes="Secondary Small" Icon="{StaticResource SemiIconStar}" />
                                    <u:IconButton Classes="Warning Small" Icon="{StaticResource SemiIconLikeHeart}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Rating" />
                                <u:Rating
                                    AllowHalf="True"
                                    Classes="Small"
                                    Value="{Binding RatingValue}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="2"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Dual Badge" />
                                <u:DualBadge Header="v">1.0</u:DualBadge>
                            </StackPanel>
                        </Border>

                        <!--  Row 2 - IPv4Box, NumericUpDown, Slider  -->
                        <Border
                            Grid.Row="2"
                            Grid.Column="0"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="IPv4Box" />
                                <u:IPv4Box Width="180" IPAddress="{Binding IpAddress}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Grid.Column="1"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="NumericUpDown" />
                                <NumericUpDown Width="120" Value="{Binding SliderValue}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Grid.Column="2"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Slider" />
                                <Slider
                                    Maximum="100"
                                    Minimum="0"
                                    Value="{Binding SliderValue}" />
                            </StackPanel>
                        </Border>

                        <!--  Row 3 - RangeSlider, MultiComboBox, TreeComboBox  -->
                        <Border
                            Grid.Row="3"
                            Grid.Column="0"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="RangeSlider" />
                                <u:RangeSlider
                                    LowerValue="{Binding LowerValue}"
                                    Maximum="100"
                                    Minimum="0"
                                    UpperValue="{Binding UpperValue}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="3"
                            Grid.Column="1"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="MultiComboBox" />
                                <u:MultiComboBox
                                    Width="180"
                                    ItemsSource="{Binding ComboBoxItems}"
                                    Watermark="Select..." />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="3"
                            Grid.Column="2"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="TreeComboBox" />
                                <u:TreeComboBox Width="180" Watermark="Select...">
                                    <u:TreeComboBoxItem Header="Item 1">
                                        <u:TreeComboBoxItem Header="Sub 1" />
                                        <u:TreeComboBoxItem Header="Sub 2" />
                                    </u:TreeComboBoxItem>
                                    <u:TreeComboBoxItem Header="Item 2" />
                                </u:TreeComboBox>
                            </StackPanel>
                        </Border>

                        <!--  Row 4 - TagInput, MultiAutoCompleteBox, Breadcrumb  -->
                        <Border
                            Grid.Row="4"
                            Grid.Column="0"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="TagInput" />
                                <u:TagInput
                                    Width="180"
                                    Watermark="Add tags..."
                                    Tags="{Binding TagItems}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="4"
                            Grid.Column="1"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="MultiAutoComplete" />
                                <u:MultiAutoCompleteBox
                                    Width="180"
                                    ItemsSource="{Binding AutoCompleteItems}"
                                    Watermark="Type...">
                                    <u:MultiAutoCompleteBox.ItemTemplate>
                                        <DataTemplate DataType="pages:ControlData">
                                            <TextBlock Text="{Binding MenuHeader}" />
                                        </DataTemplate>
                                    </u:MultiAutoCompleteBox.ItemTemplate>
                                </u:MultiAutoCompleteBox>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="4"
                            Grid.Column="2"
                            Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Breadcrumb" />
                                <u:Breadcrumb>
                                    <TextBlock Text="Home" />
                                    <TextBlock Text="Ursa" />
                                    <TextBlock Text="Intro" />
                                </u:Breadcrumb>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  Date and Time Pickers Row  -->
                    <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto">
                        <Border Grid.Column="0" Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="DateRangePicker" />
                                <u:DateRangePicker
                                    Width="220"
                                    SelectedEndDate="{Binding EndDate}"
                                    SelectedStartDate="{Binding StartDate}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="DateTimePicker" />
                                <u:DateTimePicker Width="220" SelectedDate="{Binding DateTime}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Classes="SectionCard">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="TimeRangePicker" />
                                <u:TimeRangePicker
                                    Width="220"
                                    EndTime="{Binding EndTime}"
                                    StartTime="{Binding StartTime}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  ToolBar  -->
                    <Border Classes="SectionCard">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionTitle" Text="ToolBar" />
                            <u:ToolBar Header="Actions">
                                <Button Classes="Small" Content="Save" />
                                <u:ToolBarSeparator />
                                <Button Classes="Small" Content="Load" />
                                <Button Classes="Small" Content="Delete" />
                            </u:ToolBar>
                        </StackPanel>
                    </Border>

                    <!--  Pagination  -->
                    <Border Classes="SectionCard">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionTitle" Text="Pagination" />
                            <u:Pagination
                                HorizontalAlignment="Center"
                                PageSizeOptions="10, 20, 50"
                                ShowPageSizeSelector="True"
                                TotalCount="500" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <u:OverlayDialogHost />
        </Panel>

    </pipboy:CrtDisplay>
</UserControl>
