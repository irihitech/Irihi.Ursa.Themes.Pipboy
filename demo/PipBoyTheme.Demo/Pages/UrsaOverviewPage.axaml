<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
             xmlns:u="https://irihi.tech/ursa"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="PipBoyTheme.Demo.Pages.UrsaOverviewPage">
    <pipboy:CrtDisplay
        x:Name="OverviewCrt"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        EnableFlicker="False"
        EnableNoise="True"
        EnableScanBeam="True"
        EnableScanlines="True"
        EnableScanlineAnimation="False"
        EnableVignette="True"
        NoiseDensity="0.015"
        NoiseOpacity="0.04"
        ScanBeamHeight="50"
        ScanBeamSpeed="55"
        ScanlineOpacity="0.22"
        ScanlineSpacing="3"
        VignetteIntensity="0.38">
        
        <Panel>
            <StackPanel>
                <Button Width="150" Content="Dialog" Click="Button_OnClick"></Button>
                <u:NumericIntUpDown />
                <u:DateTimePicker />
                
            </StackPanel>
            <u:OverlayDialogHost />
        </Panel>
        
    </pipboy:CrtDisplay>
</UserControl>
